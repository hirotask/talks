#!/usr/bin/env bash
set -euo pipefail

has() { command -v "$1" >/dev/null 2>&1; }

## Anyenv install
AnyenvDir="$HOME/.anyenv"
if [ ! -d "$AnyenvDir" ]; then
  git clone https://github.com/anyenv/anyenv "$AnyenvDir"
fi
export PATH="$PATH:$AnyenvDir/bin"

if has anyenv; then
  eval "$(anyenv init -)"
fi

# anyenv definitions init:
AnyenvDefRoot="$HOME/.config/anyenv/anyenv-install"
if [ ! -d "$AnyenvDefRoot" ]; then
  anyenv install --init
  eval "$(anyenv init -)"
fi

## Nodeenv install
if ! has nodenv; then
  anyenv install nodenv
  note_magenta 'nodenv installed. If nodenv/node is not found, run: direnv reload (or: exec -l $SHELL)'
  eval "$(anyenv init -)"
fi
if has nodenv; then
  eval "$(nodenv init -)"
fi

if has nodenv; then
  CurrentNodeVersion="$(node --version 2>/dev/null || true)"
  if [ "$CurrentNodeVersion" != "v24.13.0" ]; then
    nodenv install -s 24.13.0
    nodenv rehash
  fi
  nodenv shell 24.13.0 >/dev/null 2>&1 || true
fi

## pnpm install
if has corepack; then
  corepack enable
  export PATH="$PATH:$(pwd)/.pnpm-bin"
fi
